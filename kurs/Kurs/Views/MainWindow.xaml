<Window x:Class="Kurs.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kurs.ViewModels"
        mc:Ignorable="d"
        Title="АвтоТрансРасчёт - Курсовая работа" 
        Height="850" Width="1300"
        WindowStartupLocation="CenterScreen"
        FontSize="13"
        Background="#F5F5F5">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="АвтоТрансРасчёт - система расчёта стоимости грузоперевозок" 
                           FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Курсовая работа" 
                           FontSize="14" Foreground="#E3F2FD" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Панель ввода параметров -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Левая колонка -->
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Пункт отправления:" FontWeight="Bold" Margin="0,5"/>
                    <TextBox Text="{Binding DeparturePoint, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,10" FontSize="14"/>

                    <TextBlock Text="Пункт назначения:" FontWeight="Bold" Margin="0,5"/>
                    <TextBox Text="{Binding DestinationPoint, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,10" FontSize="14"/>

                    <TextBlock Text="Тип груза:" FontWeight="Bold" Margin="0,5"/>
                    <ComboBox ItemsSource="{Binding CargoTypes}" 
                              SelectedItem="{Binding SelectedCargoType}"
                              DisplayMemberPath="Name"
                              Padding="8" Margin="0,0,0,10" FontSize="14"/>
                </StackPanel>

                <!-- Правая колонка -->
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Тариф:" FontWeight="Bold" Margin="0,5"/>
                    <ComboBox ItemsSource="{Binding Tariffs}" 
                              SelectedItem="{Binding SelectedTariff}"
                              DisplayMemberPath="Name"
                              Padding="8" Margin="0,0,0,10" FontSize="14"/>

                    <TextBlock Text="Вес (тонн):" FontWeight="Bold" Margin="0,5"/>
                    <TextBox Text="{Binding WeightTons, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,10" FontSize="14"/>

                    <TextBlock Text="Объём (м³):" FontWeight="Bold" Margin="0,5"/>
                    <TextBox Text="{Binding VolumeM3, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,10" FontSize="14"/>

                    <CheckBox Content="Срочная доставка (+20%)" 
                              IsChecked="{Binding IsUrgent}"
                              Margin="0,5" FontSize="14"/>

                    <TextBlock Text="Особые условия:" FontWeight="Bold" Margin="0,5"/>
                    <TextBox Text="{Binding SpecialConditions}" 
                             Padding="8" Margin="0,0,0,10" Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная часть -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список дополнительных услуг -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Дополнительные услуги" FontSize="16" FontWeight="Bold" 
                               Foreground="#2196F3" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <ListBox x:Name="ServicesListBox"
                             ItemsSource="{Binding AdditionalServices}" 
                             SelectionMode="Multiple"
                             DisplayMemberPath="Name"
                             Background="White" 
                             BorderBrush="Gray" 
                             Height="400"
                             SelectionChanged="ServicesListBox_SelectionChanged"
                             FontSize="14"/>

                    <TextBlock Text="Выбрано услуг:" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedServices.Count}" 
                               FontWeight="Bold" Foreground="#2196F3"/>
                </StackPanel>
            </Border>

            <!-- Результаты расчёта -->
            <Border Grid.Column="1" Style="{StaticResource SectionBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Результаты расчёта" FontSize="16" FontWeight="Bold" 
                                   Foreground="#2196F3" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ИНФОРМАЦИЯ О МАРШРУТЕ" FontWeight="Bold" 
                                           Foreground="#2196F3" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentCalculation.DeparturePoint, StringFormat='Отправление: {0}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.DestinationPoint, StringFormat='Назначение: {0}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.DistanceKm, StringFormat='Расстояние: {0:F0} км'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ДЕТАЛИЗАЦИЯ СТОИМОСТИ" FontWeight="Bold" 
                                           Foreground="#2196F3" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentCalculation.BaseCost, StringFormat='Базовая стоимость: {0:C}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.CargoCoefficient, StringFormat='Коэффициент груза: {0:F2}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.AdjustedCost, StringFormat='С учётом коэффициента: {0:C}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.ServicesCost, StringFormat='Доп. услуги: {0:C}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.UrgentSurcharge, StringFormat='Срочность: {0:C}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <Border Background="#4CAF50" Padding="10" CornerRadius="5" Margin="0,15,0,0">
                                    <TextBlock Text="{Binding CurrentCalculation.TotalCost, StringFormat='ИТОГО: {0:C}'}" 
                                               FontWeight="Bold" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="ДОКУМЕНТЫ" FontWeight="Bold" 
                                           Foreground="#2196F3" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentCalculation.OfferNumber, StringFormat='Номер предложения: {0}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.CalculationNumber, StringFormat='Номер расчёта: {0}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentCalculation.CalculationDate, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}" 
                                           Margin="10,0,0,5" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Панель кнопок -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,10,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="Рассчитать" Command="{Binding CalculateCommand}" 
                        Style="{StaticResource ActionButton}" Background="#2196F3"/>
                <Button Content="Сохранить" Command="{Binding SaveCalculationCommand}" 
                        Style="{StaticResource ActionButton}" Background="#4CAF50"/>
                <Button Content="Сформировать предложение" Command="{Binding GenerateOfferCommand}" 
                        Style="{StaticResource ActionButton}" Background="#FF9800" Width="180"/>
                <Button Content="Очистить форму" Command="{Binding ClearFormCommand}" 
                        Style="{StaticResource ActionButton}" Background="#9E9E9E"/>
                <Button Content="История расчётов" Command="{Binding OpenHistoryCommand}" 
                        Style="{StaticResource ActionButton}" Background="#9C27B0"/>
            </WrapPanel>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="4" Margin="0,10,0,0" Background="#E0E0E0" Height="30">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>