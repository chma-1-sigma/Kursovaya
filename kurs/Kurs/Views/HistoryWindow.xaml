<Window x:Class="Kurs.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История расчётов" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FontSize="13"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="История выполненных расчётов" 
                       FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Панель фильтрации и поиска -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" 
                         Grid.Column="0"
                         Padding="8" 
                         FontSize="14"
                         Margin="0,0,10,0"
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Введите текст для поиска"/>

                <Button Grid.Column="1" 
                        Content="Поиск" 
                        Click="SearchButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#2196F3"
                        Width="100"/>
            </Grid>
        </Border>

        <!-- Таблица с историей -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Список расчётов" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#2196F3" 
                           Margin="0,0,0,10"/>

                <DataGrid x:Name="HistoryDataGrid" 
                          Grid.Row="1"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="White" 
                          BorderBrush="#E0E0E0"
                          RowHeight="35"
                          FontSize="13"
                          SelectionChanged="HistoryDataGrid_SelectionChanged">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" 
                                            Binding="{Binding Id}" 
                                            Width="50"/>

                        <DataGridTextColumn Header="Номер расчёта" 
                                            Binding="{Binding CalculationNumber}" 
                                            Width="120"/>

                        <DataGridTextColumn Header="Дата" 
                                            Binding="{Binding CalculationDate, StringFormat=dd.MM.yyyy HH:mm}" 
                                            Width="130"/>

                        <DataGridTextColumn Header="Отправление" 
                                            Binding="{Binding DeparturePoint}" 
                                            Width="150"/>

                        <DataGridTextColumn Header="Назначение" 
                                            Binding="{Binding DestinationPoint}" 
                                            Width="150"/>

                        <DataGridTextColumn Header="Расстояние" 
                                            Binding="{Binding DistanceKm, StringFormat={}{0:F0} км}" 
                                            Width="80"/>

                        <DataGridTextColumn Header="Вес (т)" 
                                            Binding="{Binding WeightTons, StringFormat={}{0:F2}}" 
                                            Width="70"/>

                        <DataGridTextColumn Header="Тип груза" 
                                            Binding="{Binding CargoType.Name}" 
                                            Width="120"/>

                        <DataGridTextColumn Header="Стоимость" 
                                            Binding="{Binding TotalCost, StringFormat=C}" 
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Детали выбранного расчёта -->
        <Border Grid.Row="3" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="Детали выбранного расчёта" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#2196F3" 
                           Margin="0,0,0,10"/>

                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DetailsTextBlock" 
                               Text="Выберите расчёт для просмотра деталей" 
                               TextWrapping="Wrap"
                               FontSize="13"
                               Padding="5"
                               Background="#F9F9F9"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Кнопки управления -->
        <Border Grid.Row="4" Background="#F0F0F0" Padding="10" CornerRadius="5">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="Просмотреть детали" 
                        x:Name="ViewDetailsButton"
                        Click="ViewDetailsButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#4CAF50"
                        IsEnabled="False"/>

                <Button Content="Сформировать предложение" 
                        x:Name="GenerateOfferButton"
                        Click="GenerateOfferButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#FF9800" 
                        Width="180"
                        IsEnabled="False"/>

                <Button Content="Удалить" 
                        x:Name="DeleteButton"
                        Click="DeleteButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#F44336"
                        IsEnabled="False"/>

                <Button Content="Обновить" 
                        Click="RefreshButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#9C27B0"/>

                <Button Content="Закрыть" 
                        Click="CloseButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#607D8B"/>
            </WrapPanel>
        </Border>
    </Grid>
</Window>