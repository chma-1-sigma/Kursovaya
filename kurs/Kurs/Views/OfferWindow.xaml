<Window x:Class="Kurs.Views.OfferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Коммерческое предложение" 
        Height="800" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="White">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <TextBlock Text="КОММЕРЧЕСКОЕ ПРЕДЛОЖЕНИЕ" 
                       FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="OfferTextBlock" 
                       TextWrapping="Wrap" 
                       FontSize="14" 
                       FontFamily="Consolas"
                       Padding="10"
                       Background="#F9F9F9"/>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,20,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="Печать" 
                        Click="PrintButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#4CAF50"/>
                <Button Content="Сохранить в файл" 
                        Click="SaveButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#2196F3"
                        Width="140"/>
                <Button Content="Закрыть" 
                        Click="CloseButton_Click"
                        Style="{StaticResource ActionButton}" 
                        Background="#607D8B"/>
            </WrapPanel>
        </Border>
    </Grid>
</Window>