<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
		<section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
	</configSections>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<connectionStrings>
		<!-- Для SQL Server Express -->
		<add name="KursConnection"
			 connectionString="Server=.\SQLEXPRESS;Database=Kursovaya;Trusted_Connection=True;MultipleActiveResultSets=true;"
			 providerName="System.Data.SqlClient" />

		<!-- Для LocalDB (если нет SQL Server Express) -->
		<!--
    <add name="KursConnection" 
         connectionString="Server=(localdb)\MSSQLLocalDB;Database=Kursovaya;Trusted_Connection=True;MultipleActiveResultSets=true;" 
         providerName="System.Data.SqlClient" />
    -->
	</connectionStrings>
	<entityFramework>
		<defaultConnectionFactory type="System.Data.Entity.Infrastructure.SqlConnectionFactory, EntityFramework">
			<parameters>
				<parameter value="System.Data.SqlClient" />
			</parameters>
		</defaultConnectionFactory>
		<providers>
			<provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
		</providers>
	</entityFramework>
</configuration>